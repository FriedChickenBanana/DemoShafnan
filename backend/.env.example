# Server
PORT=3000
NODE_ENV=development

# Shared secret for HMAC request signing (extension must have matching value at build time)
SHARED_SECRET=change_me_to_a_long_random_string

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/truthlens

# Redis
REDIS_URL=redis://localhost:6379

# AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Fact-check APIs
GOOGLE_FACT_CHECK_API_KEY=your_google_api_key_here
CLAIMBUSTER_API_KEY=your_claimbuster_api_key_here

# Image analysis
SERPAPI_KEY=your_serpapi_key_here
HIVE_AI_KEY=your_hive_ai_key_here

# AI text detection
GPTZERO_API_KEY=your_gptzero_api_key_here

# News
NEWS_API_KEY=your_newsapi_key_here

# Embeddings (for F5 claim sync)
VOYAGE_API_KEY=your_voyage_api_key_here
